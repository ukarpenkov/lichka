<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/alarm_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="28dp">

            <TextView
                android:id="@+id/top_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="БУДИЛЬНИК"
                android:textSize="12sp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/status_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Alarm Icon with Pulse Rings -->
            <FrameLayout
                android:layout_width="136dp"
                android:layout_height="136dp"
                android:layout_gravity="center">

                <View
                    android:id="@+id/alarm_pulse_ring_1"
                    android:layout_width="136dp"
                    android:layout_height="136dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_alarm_pulse_ring" />

                <View
                    android:id="@+id/alarm_pulse_ring_2"
                    android:layout_width="136dp"
                    android:layout_height="136dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_alarm_pulse_ring" />

                <View
                    android:id="@+id/alarm_icon_ring"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_alarm_icon_ring" />

                <ImageView
                    android:id="@+id/alarm_icon"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_alarm_clock" />
            </FrameLayout>

            <!-- Pixel clock time -->
            <TextView
                android:id="@+id/alarm_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:textSize="40sp"
                android:gravity="center"
                android:includeFontPadding="false" />

            <!-- Alarm Label -->
            <TextView
                android:id="@+id/alarm_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="16sp"
                android:gravity="center"
                android:maxWidth="340dp"
                android:paddingHorizontal="16dp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/btn_dismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="Отключить"
                android:textSize="15sp"
                android:textColor="#E53935"
                android:drawableStart="@drawable/ic_dismiss"
                android:drawablePadding="8dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_snooze"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingVertical="8dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="Отложить · 5 мин"
                android:textSize="15sp"
                android:drawableStart="@drawable/ic_snooze"
                android:drawablePadding="8dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
